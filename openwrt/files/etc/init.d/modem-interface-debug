#!/bin/sh /etc/rc.common

# Modem Interface Service - DEBUG VERSION
# Manages the modem-interface web application

START=99
STOP=10

USE_PROCD=1
PROG=/usr/bin/modem-interface

start_service() {
	procd_open_instance

	# Main command - wrapped in sh to capture any startup errors
	procd_set_param command /bin/sh -c "cd / && exec $PROG 2>&1"

	# Environment variables
	procd_set_param env STATIC_FILES_PATH=/www/modem-interface
	procd_set_param env LISTEN_ADDR=0.0.0.0:8080
	procd_set_param env RUST_LOG=debug
	procd_set_param env RUST_BACKTRACE=1

	# Set working directory explicitly
	procd_set_param dir /tmp

	# Respawn parameters: threshold timeout retry
	procd_set_param respawn 60 5 5

	# Log stdout and stderr
	procd_set_param stdout 1
	procd_set_param stderr 1

	procd_close_instance
}

stop_service() {
	killall modem-interface 2>/dev/null || true
}

reload_service() {
	stop
	start
}

service_triggers() {
	procd_add_reload_trigger "modem-interface"
}
